{
    "name": "enlivenapp/flight-school",
    "description": "Plugin loader and discovery for FlightPHP plugins",
    "type": "composer-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "enlivenapp",
            "email": "mw@enlivenapp.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "composer-plugin-api": "^2.0",
        "flightphp/core": "^3.0",
        "flightphp/runway": "^1.1"
    },
    "suggest": {
        "enlivenapp/vision": "Required for Vision template engine rendering (used by Pubvana)"
    },
    "autoload": {
        "psr-4": {
            "Enlivenapp\\FlightSchool\\": "src/"
        }
    },
    "extra": {
        "class": "Enlivenapp\\FlightSchool\\ComposerPlugin"
    }
}
